{
  "compilerOptions": {
    "target": "es2023",
    "strictPropertyInitialization": false,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "strict": true,
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist"
  }
}
